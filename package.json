{
  "name": "signal-sky",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next/dev 2>/dev/null; next dev",
    "build": "prisma generate --schema=prisma/schema.prisma && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "remotion:studio": "npx remotion studio remotion/index.ts",
    "remotion:voiceover": "npx tsx remotion/scripts/generate-voiceover.ts",
    "remotion:voiceover:30s": "npx tsx remotion/scripts/generate-voiceover.ts 30s",
    "remotion:voiceover:60s": "npx tsx remotion/scripts/generate-voiceover.ts 60s",
    "remotion:voiceover:90s": "npx tsx remotion/scripts/generate-voiceover.ts 90s",
    "remotion:render:30s-h": "npx remotion render remotion/index.ts Promo30H out/promo-30s-horizontal.mp4",
    "remotion:render:60s-h": "npx remotion render remotion/index.ts Promo60H out/promo-60s-horizontal.mp4",
    "remotion:render:90s-h": "npx remotion render remotion/index.ts Promo90H out/promo-90s-horizontal.mp4",
    "remotion:render:30s-v": "npx remotion render remotion/index.ts Promo30V out/promo-30s-vertical.mp4",
    "remotion:render:60s-v": "npx remotion render remotion/index.ts Promo60V out/promo-60s-vertical.mp4",
    "remotion:render:90s-v": "npx remotion render remotion/index.ts Promo90V out/promo-90s-vertical.mp4",
    "remotion:render:all": "npm run remotion:render:30s-h && npm run remotion:render:60s-h && npm run remotion:render:90s-h && npm run remotion:render:30s-v && npm run remotion:render:60s-v && npm run remotion:render:90s-v",
    "remotion:voiceover:explainer": "npx tsx remotion/scripts/generate-voiceover.ts explainer",
    "remotion:render:explainer": "npx remotion render remotion/index.ts Explainer90H out/explainer-90s.mp4"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@react-email/components": "^1.0.9",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-email": "^5.2.9",
    "recharts": "^2.15.4",
    "resend": "^6.9.3",
    "shadcn": "^3.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "yahoo-finance2": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.436",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pdf-lib": "^1.17.1",
    "prisma": "^7.3.0",
    "puppeteer": "^24.39.0",
    "remotion": "^4.0.436",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "remotion": {
    "entryPoint": "remotion/index.ts"
  }
}
